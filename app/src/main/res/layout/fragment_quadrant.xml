<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lightGray"
    android:padding="4dp">

    <!-- 第一行：重要且紧急 vs 重要不紧急 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <include
            layout="@layout/quadrant_card"
            android:id="@+id/card_important_urgent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp" />

        <include
            layout="@layout/quadrant_card"
            android:id="@+id/card_important_not_urgent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp" />
    </LinearLayout>

    <!-- 第二行：不重要但紧急 vs 不重要不紧急 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <include
            layout="@layout/quadrant_card"
            android:id="@+id/card_not_important_urgent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp" />

        <include
            layout="@layout/quadrant_card"
            android:id="@+id/card_not_important_not_urgent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp" />
    </LinearLayout>
</LinearLayout>