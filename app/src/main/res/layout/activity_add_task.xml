<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task_title_label"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_outlined"
                    android:textSize="18sp"
                    android:maxLength="100"
                    android:maxLines="1"
                    android:inputType="textShortMessage"
                    android:imeOptions="flagNoExtractUi"
                    android:importantForAutofill="no"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />

                <TextView
                    android:id="@+id/tv_title_counter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="0/100"
                    android:textSize="11sp"
                    android:textColor="@color/secondaryText"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task_desc_label"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_outlined"
                    android:textSize="15sp"
                    android:maxLines="4"
                    android:inputType="textLongMessage|textMultiLine"
                    android:imeOptions="flagNoExtractUi"
                    android:gravity="top"
                    android:importantForAutofill="no"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:minHeight="120dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Priority Card (四象限选择) -->
        <!-- Priority Card（高、中、低、无） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/priority_label"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryText"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_high"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="高"
                        android:textColor="@color/white"
                        android:checkable="true"
                        android:checked="true"
                        android:textAlignment="center"
                        app:chipBackgroundColor="@color/priorityHigh"
                        app:checkedIconEnabled="true"
                        app:checkedIconTint="@color/white" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_medium"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:text="中"
                        android:textColor="@color/white"
                        android:checkable="true"
                        android:textAlignment="center"
                        app:chipBackgroundColor="@color/priorityMedium"
                        app:checkedIconEnabled="true"
                        app:checkedIconTint="@color/white" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_low"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:text="低"
                        android:textColor="@color/white"
                        android:checkable="true"
                        android:textAlignment="center"
                        app:chipBackgroundColor="@color/priorityLow"
                        app:checkedIconEnabled="true"
                        app:checkedIconTint="@color/white" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_none"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="无"
                        android:textColor="@color/white"
                        android:checkable="true"
                        android:textAlignment="center"
                        app:chipBackgroundColor="@color/darkGray"
                        app:checkedIconEnabled="true"
                        app:checkedIconTint="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_label"
                    android:textSize="14sp"
                    android:textColor="@color/secondaryText"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_category_work"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="@string/category_work"
                        android:checkable="true"
                        android:textSize="12sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_category_personal"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:text="@string/category_personal"
                        android:checkable="true"
                        android:textSize="12sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_category_study"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:text="@string/category_study"
                        android:checkable="true"
                        android:textSize="12sp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_category_other"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/category_other"
                        android:checkable="true"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Reminder Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:id="@+id/card_reminder">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reminder_label"
                        android:textSize="14sp"
                        android:textColor="@color/secondaryText" />

                    <TextView
                        android:id="@+id/tv_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tap_to_select_datetime"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_clear_reminder"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone"
                    android:contentDescription="@string/clear_reminder" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_cancel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_save"
                android:backgroundTint="@color/primary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>