<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: primary color border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="@color/primary" />
            <solid android:color="@android:color/transparent" />
            <padding android:left="12dp" android:right="12dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
    <!-- Default state: outline border using theme-aware color -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/darkGray" />
            <solid android:color="@android:color/transparent" />
            <padding android:left="12dp" android:right="12dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
</selector>
